ANTHROPIC_API_KEY=your_key_here
# RAG_ENABLED=1   # set to 0 to disable RAG retrieval grounding (default on; auto-off if corpus/ is empty)

# ── Only needed when serving beyond localhost ────────────────────────────────
# Every route is an unauthenticated proxy to the paid API key above, so the app
# refuses non-loopback requests unless APP_PASSWORD is set. Set it, and callers
# must supply it via HTTP basic auth (any username).
# APP_PASSWORD=choose_a_long_random_password
# TRUSTED_HOSTS=your-app.onrender.com   # comma-separated; must list the served hostname
# SECRET_KEY=random_value               # else sessions reset on every restart
# RATE_LIMIT_PER_MIN=30                 # per-IP cap on /chat and /polish
